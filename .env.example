# ─── ChromaScope — Variabili d'ambiente (Fase 5: AI Reasoning Chain) ───────
# Copia questo file in .env e compila le variabili necessarie.
# ATTENZIONE: non committare mai .env — è già in .gitignore.

# ── Provider AI ─────────────────────────────────────────────────────────────
# Provider da usare: groq | openai | claude
# Default: groq (gratuito, nessuna carta di credito richiesta)
AI_PROVIDER=groq

# ── API Key ──────────────────────────────────────────────────────────────────
# Groq:   https://console.groq.com/keys
# OpenAI: https://platform.openai.com/api-keys
AI_API_KEY=your_groq_or_openai_api_key_here

# Solo per AI_PROVIDER=claude:
# Anthropic: https://console.anthropic.com/settings/api-keys
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Base URL (opzionale) ──────────────────────────────────────────────────────
# Override per endpoint OpenAI-compatibili (es. LM Studio, Ollama, Together AI).
# Se non specificato, usa il default del provider selezionato.
# Groq default:  https://api.groq.com/openai/v1
# OpenAI default: https://api.openai.com/v1
# AI_BASE_URL=https://api.groq.com/openai/v1

# ── Modello ───────────────────────────────────────────────────────────────────
# Override modello. Se non specificato, usa il default per il provider:
#   groq:   llama-3.3-70b-versatile  (gratuito, ottimo per ragionamento)
#   openai: gpt-4o-mini              (economico, buona qualità)
#   claude: claude-haiku-4-5-20251001 (veloce, economico)
# AI_MODEL=llama-3.3-70b-versatile
